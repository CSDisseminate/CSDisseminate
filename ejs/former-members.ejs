```{=html}
<ul class="former-list list">
<%
/* Sort: Founder first, then alphabetical by last name */
const sorted = [...items].sort((a, b) => {
  const aFounder = (a.categories || []).includes("Founder") || String(a.categories).includes("Founder");
  const bFounder = (b.categories || []).includes("Founder") || String(b.categories).includes("Founder");
  if (aFounder && !bFounder) return -1;
  if (!aFounder && bFounder) return 1;
  const aLast = (a["last-name"] || a.title || "").toLowerCase();
  const bLast = (b["last-name"] || b.title || "").toLowerCase();
  return aLast.localeCompare(bLast);
});
%>

<style>
.former-list {
  list-style: disc;
  padding-left: 1.5rem;
  margin: 0;
}

.former-list li {
  display: list-item;
  gap: .6rem;
  padding: .35rem 0;
  font-size: .95rem;
}

.former-list li:last-child {
  border-bottom: none;
}

.former-name {
  font-weight: 500;
  margin-right: .4rem;
}

.former-credentials {
  color: var(--bs-secondary-color);
}

/* Founder badge: light mode */
.founder-badge {
  display: inline-flex;
  align-items: center;
  gap: .3rem;
  font-size: .72rem;
  line-height: 1;
  padding: .2rem .55rem;
  border-radius: 999px;
  border: 1px solid rgba(251,191,36,.35);
  background: rgba(251,191,36,.12);
  color: #78350f;
  font-weight: 500;
  vertical-align: middle;
  margin-left: .2rem;
}

.founder-badge .bi {
  font-size: .85em;
  color: inherit;
}

/* Founder badge: dark mode */
body.quarto-dark .former-credentials {
  color: var(--bs-secondary-color);
}

body.quarto-dark .founder-badge {
  background: rgba(250, 204, 21, 0.18) !important;
  color: rgba(255, 255, 255, 0.92) !important;
  border-color: rgba(250, 204, 21, 0.28) !important;
}

body.quarto-dark .founder-badge .bi {
  color: inherit !important;
}
</style>

<% for (const item of sorted) {
  const isFounder = (item.categories || []).includes("Founder") || String(item.categories).includes("Founder");
%>
  <li>
    <span class="former-name"><%= item.title %></span>
    <% if (item.credentials) { %>
      <span class="former-credentials"><%= item.credentials %></span>
    <% } %>
    <% if (isFounder) { %>
      <span class="founder-badge">
        <i class="bi bi-award-fill" aria-hidden="true"></i>
        Founder
      </span>
    <% } %>
  </li>
<% } %>
</ul>
```
