```{=html}
<style>
.pub-list {
  list-style: none;
  padding-left: 0;
  margin: 0;
}

.pub-list li {
  padding: 1.1rem 0;
  border-bottom: 1px solid var(--bs-border-color);
}

.pub-list li:last-child {
  border-bottom: none;
}

.pub-buttons {
  margin-top: 0.75rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

/* Base button cleanup */
.pub-buttons .btn {
  border-radius: 999px;
  font-weight: 500;
  padding: 0.38rem 0.8rem;
  line-height: 1.2;
  box-shadow: none;
}

/* Primary button: keep stronger */
.pub-buttons .btn-primary {
  background: var(--bs-primary);
  border-color: var(--bs-primary);
  color: #fff;
}

.pub-buttons .btn-primary:hover {
  filter: brightness(1.05);
}

/* Soft purple pills */
.pub-buttons .btn-secondary {
  background: rgba(124, 58, 237, 0.12);
  border: 1px solid rgba(124, 58, 237, 0.24);
  color: #8966AB;
}

.pub-buttons .btn-secondary:hover {
  background: rgba(124, 58, 237, 0.18);
  border-color: rgba(124, 58, 237, 0.32);
  color: #8966AB;
}

/* TEXT-ONLY buttons (this is the key change) */
.pub-buttons .btn-tertiary {
  background: transparent;
  border: none;
  padding: 0.38rem 0.4rem; /* tighter so it feels like text */
  color: var(--bs-secondary-color);
}

.pub-buttons .btn-tertiary:hover {
  color: var(--bs-body-color);
  text-decoration: underline;
}

/* Dark mode adjustments */
body.quarto-dark .pub-list li {
  border-bottom: 1px solid rgba(255,255,255,0.08);
}

body.quarto-dark .pub-buttons .btn-secondary {
  background: rgba(167, 139, 250, 0.18);
  border-color: rgba(167, 139, 250, 0.30);
  color: rgba(255, 255, 255, 0.92);
}

body.quarto-dark .pub-buttons .btn-secondary:hover {
  background: rgba(167, 139, 250, 0.24);
  border-color: rgba(167, 139, 250, 0.38);
  color: rgba(255, 255, 255, 0.96);
}

body.quarto-dark .pub-buttons .btn-tertiary {
  background: transparent;
  border: none;
  padding: 0.38rem 0.4rem; /* tighter so it feels like text */
  color: var(--bs-secondary-color);
}

body.quarto-dark .pub-buttons .btn-tertiary:hover {
  color: var(--bs-body-color);
  text-decoration: underline;
}

body.quarto-dark .pub-buttons .btn-primary {
  color: #fff;
}
</style>

<ul class="pub-list list">
<% for (const item of items) { %>
  <li <%= metadataAttrs(item) %>>
    <h5 style="margin: 0;"><strong><%= item.title %></strong></h5>
    <%= item.author %><br />
    <em><%= item.publication %></em>
    (<%= item.year %>)<br />
    <div class="pub-buttons">
      <a href="<%- item.path %>" class="btn btn-primary">
        Details
      </a>
      <% if (item.links && item.links.doi && item.links.doi.link) { %>
      <a href="<%- item.links.doi.link %>" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
        DOI
      </a>
      <% } %>
      <% if (item.links && item.links.oa && item.links.oa.link) { %>
      <a href="<%- item.links.oa.link %>" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
        <i class="bi bi-file-pdf"></i> Open Access
      </a>
      <% } %>
      <% if (item.links && item.links.postprint && item.links.postprint.link) { %>
      <a href="<%- item.links.postprint.link %>" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
        <i class="bi bi-file-earmark-text"></i> Postprint
      </a>
      <% } %>
      <% if (item.links && item.links.pubmed && item.links.pubmed.link) { %>
      <a href="<%- item.links.pubmed.link %>" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
        <i class="bi bi-file-medical"></i> PubMed
      </a>
      <% } %>
      <% if (item.links && item.links.preprint && item.links.preprint.link) { %>
      <a href="<%- item.links.preprint.link %>" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
        <i class="bi bi-file-text"></i> Preprint
      </a>
      <% } %>
      <% if (item.links && item.links.materials && item.links.materials.link) { %>
      <a href="<%- item.links.materials.link %>" class="btn btn-tertiary" target="_blank" rel="noopener noreferrer">
        <i class="bi bi-box-seam"></i> Materials
      </a>
      <% } %>
      <% if (item.links && item.links.preregistration && item.links.preregistration.link) { %>
      <a href="<%- item.links.preregistration.link %>" class="btn btn-tertiary" target="_blank" rel="noopener noreferrer">
        <i class="bi bi-journal-check"></i> Preregistration
      </a>
      <% } %>
      <% if (item.links && item.links.other && item.links.other.link) { %>
      <a href="<%- item.links.other.link %>" class="btn btn-tertiary" target="_blank" rel="noopener noreferrer">
        <i class="bi bi-globe"></i> Article
      </a>
      <% } %>
    </div>
  </li>
<% } %>
</ul>

```