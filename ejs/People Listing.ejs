```{=html}
<ul class="people-list list">
<%
/* Resolve headshot/image path */
function resolveImg(item) {
  const img = item.headshot || item.image || item.thumbnail;
  if (!img) return null;
  if (/^https?:\/\//i.test(img)) return img;
  const base = (item.path || "").replace(/[^/]+$/, "");
  const enc = encodeURI(img).replace(/%2F/gi, "/");
  return base + enc;
}

/* Role badge config — label, icon, colors */
const ROLE_BADGES = {
  "Chair": {
    icon: "bi-star-fill",
    bg: "rgba(124,58,237,.12)",
    color: "#4c1d95",
    border: "rgba(124,58,237,.25)"
  },
  "Vice-Chair & Secretary": {
    icon: "bi-bookmark-star-fill",
    bg: "rgba(79,70,229,.12)",
    color: "#1e1b4b",
    border: "rgba(79,70,229,.25)"
  },
  "Treasurer": {
    icon: "bi-cash-stack",
    bg: "rgba(16,185,129,.12)",
    color: "#065f46",
    border: "rgba(16,185,129,.25)"
  },
  "Board Member": {
    icon: "bi-people-fill",
    bg: "rgba(59,130,246,.12)",
    color: "#1e3a8a",
    border: "rgba(59,130,246,.25)"
  },
  "Website Team Lead": {
    icon: "bi-code-slash",
    bg: "rgba(234,179,8,.12)",
    color: "#713f12",
    border: "rgba(234,179,8,.25)"
  },
  "Ambassador Team Lead": {
    icon: "bi-megaphone-fill",
    bg: "rgba(239,68,68,.12)",
    color: "#7f1d1d",
    border: "rgba(239,68,68,.25)"
  },
  "Social Media Team Lead": {
    icon: "bi-chat-heart-fill",
    bg: "rgba(236,72,153,.12)",
    color: "#831843",
    border: "rgba(236,72,153,.25)"
  }
};

/* Get role badges for an item, skipping "Collaborator" */
function getRoleBadges(item) {
  const cats = item.categories;
  if (!cats) return [];
  const list = Array.isArray(cats) ? cats : String(cats).split(",").map(s => s.trim());
  return list
    .filter(c => ROLE_BADGES[c])
    .map(c => ({ label: c, ...ROLE_BADGES[c] }));
}
%>

<style>
/* ---- GRID ---- */
.people-list {
  display: grid;
  gap: 1.5rem;
  padding-left: 0;
  list-style: none;
  margin-top: 1rem;
  grid-template-columns: repeat(1, minmax(0, 1fr));
}
@media (min-width: 640px) {
  .people-list { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (min-width: 1024px) {
  .people-list { grid-template-columns: repeat(3, minmax(0, 1fr)); }
}

/* ---- Card ---- */
.people-list .card {
  background: #fff;
  border: 1px solid #e5e5e5;
  border-radius: 1rem;
  overflow: hidden;
  box-shadow: 0 2px 6px rgba(0,0,0,0.05);
  transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
  text-align: left;
}
.people-list .card:hover {
  transform: translateY(-3px);
  box-shadow: 0 6px 18px rgba(0,0,0,0.08);
}

/* ---- Square image ---- */
.people-list .card-img-top {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  border-radius: 1rem 1rem 0 0;
}
.people-list .card-img-top img {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}

/* ---- Text ---- */
.people-list .card-body { padding: 1em; }
.people-list .card-title { font-weight: 600; margin-bottom: .25em; font-size: 1.05em; line-height: 1.3; }
.people-list .credentials { font-size: .9em; color: #555; margin-bottom: .25em; }
.people-list .affiliation { font-size: .9em; color: #666; line-height: 1.3; margin-bottom: .5em; }

/* ---- Role badges ---- */
.role-badges { display: flex; flex-wrap: wrap; gap: .35rem; margin-top: .5rem; }
.role-badge {
  display: inline-flex;
  align-items: center;
  gap: .3rem;
  font-size: .72rem;
  line-height: 1;
  padding: .2rem .55rem;
  border-radius: 999px;
  border: 1px solid transparent;
  font-weight: 500;
}
.role-badge .bi { font-size: .85em; }
</style>

<% for (const item of items) {
     const imgSrc = resolveImg(item);
     const badges = getRoleBadges(item);
%>
  <li class="card" <%= metadataAttrs(item) %>>
    <a href="<%- item.path %>" style="text-decoration:none;color:inherit;">
      <% if (imgSrc) { %>
        <div class="card-img-top">
          <img src="<%- imgSrc %>" alt="<%= item.pagetitle || item.title %>">
        </div>
      <% } %>
      <div class="card-body">
        <h5 class="card-title"><%= item.pagetitle || item.title %></h5>
        <% if (item.credentials) { %><div class="credentials"><%= item.credentials %></div><% } %>
        <% if (item.affiliation) { %><div class="affiliation"><%= item.affiliation %></div><% } %>
        <% if (badges.length > 0) { %>
          <div class="role-badges">
            <% for (const b of badges) { %>
              <span class="role-badge" style="background:<%= b.bg %>;color:<%= b.color %>;border-color:<%= b.border %>">
                <i class="bi <%= b.icon %>" aria-hidden="true"></i>
                <%= b.label %>
              </span>
            <% } %>
          </div>
        <% } %>
      </div>
    </a>
  </li>
<% } %>
</ul>
```