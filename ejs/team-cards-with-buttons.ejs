<ul class="people-list list">
<%
/* Resolve headshot/image path */
function resolveImg(item) {
  const img = item.headshot || item.image || item.thumbnail;
  if (!img) return null;
  if (/^https?:\/\//i.test(img)) return img;
  const base = (item.path || "").replace(/[^/]+$/, "");
  const enc = encodeURI(img).replace(/%2F/gi, "/");
  return base + enc;
}

/* Role badge config — label, icon, and which hue from the shared badge
   palette to use. The palette itself is defined per theme in
   styles/cosmo-custom.scss and styles/solar-custom.scss, so dark mode needs
   no overrides here. To recolour a role, change `hue` (or the token). */
const ROLE_BADGES = {
  "Chair":                  { icon: "bi-star-fill",          hue: "violet"  },
  "Vice-Chair & Secretary": { icon: "bi-bookmark-star-fill", hue: "indigo"  },
  "Treasurer":              { icon: "bi-cash-stack",         hue: "emerald" },
  "Board Member":           { icon: "bi-people-fill",        hue: "blue"    },
  "Website Team Lead":      { icon: "bi-code-slash",         hue: "amber"   },
  "Ambassador Team Lead":   { icon: "bi-megaphone-fill",     hue: "red"     },
  "Social Media Team Lead": { icon: "bi-chat-heart-fill",    hue: "pink"    }
};

/* Get role badges for an item, skipping "Collaborator" */
function getRoleBadges(item) {
  const cats = item.categories;
  if (!cats) return [];
  const list = Array.isArray(cats) ? cats : String(cats).split(",").map(s => s.trim());
  return list
    .filter(c => ROLE_BADGES[c])
    .map(c => ({ label: c, ...ROLE_BADGES[c] }));
}
%>

<style>
/* ---- GRID ---- */
.people-list {
  display: grid;
  gap: 1.5rem;
  padding-left: 0;
  list-style: none;
  margin-top: 1rem;
  grid-template-columns: repeat(1, minmax(0, 1fr));
}
@media (min-width: 640px) {
  .people-list { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (min-width: 1024px) {
  .people-list { grid-template-columns: repeat(3, minmax(0, 1fr)); }
}

/* ---- Card ---- */
.people-list .card {
  background: var(--bs-card-bg);
  border: 1px solid var(--bs-border-color);
  border-radius: var(--csd-radius-card);
  overflow: hidden;
  box-shadow: var(--csd-shadow-card);
  transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
  text-align: left;
  max-width: 340px;
}

.people-list .card:hover {
  transform: translateY(-3px);
  box-shadow: var(--csd-shadow-card-hover);
}

/* ---- Square image ---- */
.people-list .card-img-top {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  border-radius: var(--csd-radius-card) var(--csd-radius-card) 0 0;
}
.people-list .card-img-top img {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}

/* ---- Text ---- */
.people-list .card-body {
  padding: 1em;
}

.people-list .card-title {
  font-weight: 600;
  margin-bottom: .25em;
  font-size: 1.05em;
  line-height: 1.3;
}

.people-list .credentials {
  font-size: .9em;
  color: var(--csd-text-muted);
  margin-bottom: .25em;
}

.people-list .affiliation {
  font-size: .9em;
  color: var(--csd-text-muted);
  line-height: 1.3;
  margin-bottom: .5em;
}


/* ---- Role badges ---- */
.role-badges { display: flex; flex-wrap: wrap; gap: .35rem; margin-top: .5rem; }
.role-badge {
  display: inline-flex;
  align-items: center;
  gap: .3rem;
  font-size: .72rem;
  line-height: 1;
  padding: .2rem .55rem;
  border-radius: var(--csd-radius-pill);
  border: 1px solid transparent;
  font-weight: 500;
}
.role-badge .bi { font-size: .85em; color: inherit; }

/* Dark mode needs no rules here: the badge tokens above resolve to their
   dark values from solar-custom.scss. This replaced seven selectors that
   matched on substrings of the inline style attribute
   (e.g. `.role-badge[style*="124,58,237"]`) and broke whenever a colour
   literal changed. */
</style>

<% for (const item of items) {
     const imgSrc = resolveImg(item);
     const badges = getRoleBadges(item);
%>
  <li class="card" <%= metadataAttrs(item) %>>
    <a href="<%- item.path %>" style="text-decoration:none;color:inherit;">
      <% if (imgSrc) { %>
        <div class="card-img-top">
          <img src="<%- imgSrc %>" alt="<%= item.pagetitle || item.title %>">
        </div>
      <% } %>
      <div class="card-body">
        <h5 class="card-title"><%= item.pagetitle || item.title %></h5>
        <% if (item.credentials) { %><div class="credentials"><%= item.credentials %></div><% } %>
        <% if (item.affiliation) { %><div class="affiliation"><%= item.affiliation %></div><% } %>
        <% if (badges.length > 0) { %>
          <div class="role-badges">
            <% for (const b of badges) { %>
              <span class="role-badge" style="background:var(--csd-badge-<%= b.hue %>-bg);color:var(--csd-badge-<%= b.hue %>-text);border-color:var(--csd-badge-<%= b.hue %>-border)">
                <i class="bi <%= b.icon %>" aria-hidden="true"></i>
                <%= b.label %>
              </span>
            <% } %>
          </div>
        <% } %>
      </div>
    </a>
  </li>
<% } %>
</ul>

```