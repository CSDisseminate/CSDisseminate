<div id="resource-filter-bar" style="margin-bottom:1rem;display:flex;flex-wrap:wrap;gap:.4rem;align-items:center;">
  <span style="font-size:.85rem;margin-right:.25rem;">Filter:</span>
  <button class="resource-filter-btn active" data-cat="all"
    style="font-size:.78rem;padding:.25rem .7rem;border-radius:var(--csd-radius-pill);cursor:pointer;font-weight:500;">
    All
  </button>
</div>

<ul class="resource-list list" id="resource-list">
<%
function resolveLink(item) {
  const ext = item["resource-link"];
  if (ext && String(ext).trim().length > 0) return String(ext).trim();
  return item.path;
}
function isExternal(item) {
  const ext = item["resource-link"];
  return ext && String(ext).trim().length > 0;
}
function getCategories(item) {
  const cats = item.categories;
  if (!cats) return [];
  if (Array.isArray(cats)) return cats.map(c => String(c).trim());
  return String(cats).split(",").map(c => c.trim()).filter(Boolean);
}

/* Tag pill styling.
   This was three constants — AUDIENCE_STYLE / TOPIC_STYLE / CSD_STYLE — that
   held byte-identical values, so the "three-shade" distinction never rendered.
   Collapsed to the shared tag tokens. To reintroduce a real distinction,
   branch on the category here and add matching tokens to the theme files. */
function badgeStyle(cat) {
  return "background:var(--csd-tag-bg);color:var(--csd-tag-text);border-color:var(--csd-tag-border)";
}
%>

<style>
.resource-list {
  list-style: none;
  padding-left: 0;
  margin: 0;
}

.resource-card {
  padding: 1.1rem 0;
  border-bottom: 1px solid var(--csd-divider);
}

.resource-card:last-child {
  border-bottom: none;
}

.resource-card.hidden {
  display: none;
}

.resource-title {
  font-size: 1.1rem;
  font-weight: 700;
  margin: 0 0 .4rem 0;
}

.resource-title a {
  text-decoration: none;
  color: inherit;
  font-weight: 700;
}

.resource-title a:hover {
  text-decoration: underline;
}

.resource-external-icon {
  font-size: .8em;
  margin-left: .25rem;
  opacity: .6;
}

.resource-tags {
  display: flex;
  flex-wrap: wrap;
  gap: .3rem;
  margin-bottom: .5rem;
}

.resource-tag {
  display: inline-flex;
  align-items: center;
  font-size: .72rem;
  line-height: 1;
  padding: .18rem .5rem;
  border-radius: var(--csd-radius-pill);
  border: 1px solid transparent;
  font-weight: 500;
  cursor: pointer;
  transition: opacity .15s;
  /* reset <button> UA styles so the pill looks identical to the old <span> */
  font-family: inherit;
  appearance: none;
  -webkit-appearance: none;
}

.resource-tag:hover {
  opacity: .75;
}

.resource-desc {
  font-size: .92rem;
  color: var(--csd-text-muted);
  margin: 0;
  line-height: 1.5;
}

#resource-filter-bar span {
  color: var(--csd-text-muted) !important;
}

.resource-filter-btn {
  transition: all .15s;
  background: var(--csd-filter-bg) !important;
  border: 1px solid var(--csd-filter-border) !important;
  color: var(--csd-filter-text) !important;
}

.resource-filter-btn.active {
  background: var(--bs-primary) !important;
  color: #fff !important;
  border-color: var(--bs-primary) !important;
  font-weight: 700 !important;
}

/* ---- Dark mode ----
   The filter buttons, tag pills and card dividers all come from theme-aware
   tokens now, so the per-property dark overrides that used to live here are
   gone — including `.resource-tag[style*="124,58,237"]`, which matched on a
   substring of the inline style and broke the moment that literal changed. */
body.quarto-dark .resource-external-icon {
  opacity: 0.75;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const bar    = document.getElementById("resource-filter-bar");
  const list   = document.getElementById("resource-list");
  const active = new Set(); // tracks currently selected filters

  // Build category list from card data attributes
  const allCats = [...new Set(
    Array.from(list.querySelectorAll(".resource-card"))
      .flatMap(card => (card.dataset.categories || "").split(",").map(s => s.trim()))
      .filter(Boolean)
  )].sort();

  allCats.forEach(cat => {
    const btn = document.createElement("button");
    btn.className = "resource-filter-btn";
    btn.dataset.cat = cat;
    btn.textContent = cat;
    btn.style.cssText = "font-size:.78rem;padding:.25rem .7rem;border-radius:var(--csd-radius-pill);cursor:pointer;font-weight:500;";
    bar.appendChild(btn);
  });

  function applyFilters() {
    const allBtn = bar.querySelector(".resource-filter-btn[data-cat='all']");
    list.querySelectorAll(".resource-card").forEach(card => {
      if (active.size === 0) {
        card.classList.remove("hidden");
      } else {
        const cardCats = new Set((card.dataset.categories || "").split(",").map(s => s.trim()));
        // AND logic: card must match ALL active filters
        const matches = [...active].every(f => cardCats.has(f));
        card.classList.toggle("hidden", !matches);
      }
    });
    if (allBtn) allBtn.classList.toggle("active", active.size === 0);
  }

  bar.addEventListener("click", function(e) {
    const btn = e.target.closest(".resource-filter-btn");
    if (!btn) return;
    const cat = btn.dataset.cat;

    if (cat === "all") {
      active.clear();
      bar.querySelectorAll(".resource-filter-btn").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
    } else {
      if (active.has(cat)) {
        active.delete(cat);
        btn.classList.remove("active");
      } else {
        active.add(cat);
        btn.classList.add("active");
      }
      const allBtn = bar.querySelector(".resource-filter-btn[data-cat='all']");
      if (allBtn) allBtn.classList.toggle("active", active.size === 0);
    }

    applyFilters();
  });

  // Clicking a tag badge on a card toggles that filter
  list.addEventListener("click", function(e) {
    const tag = e.target.closest(".resource-tag");
    if (!tag) return;
    const cat = tag.dataset.cat;
    bar.querySelectorAll(".resource-filter-btn").forEach(function(btn) {
      if (btn.dataset.cat === cat) btn.click();
    });
  });
});
</script>

<% for (const item of items) {
  const href     = resolveLink(item);
  const external = isExternal(item);
  const cats     = getCategories(item);
  const desc     = item["short-description"] || item.description || "";
%>
  <li class="resource-card" data-categories="<%= cats.join(',') %>" <%= metadataAttrs(item) %>>
    <h5 class="resource-title" style="margin:0;">
      <strong>
        <a href="<%- href %>"
           <% if (external) { %> target="_blank" rel="noopener noreferrer" <% } %>>
          <%= item.title %>
          <% if (external) { %>
            <i class="bi bi-box-arrow-up-right resource-external-icon" aria-label="External link"></i>
          <% } %>
        </a>
      </strong>
    </h5>
    <% if (cats.length > 0) { %>
      <div class="resource-tags">
        <% for (const cat of cats) { %>
          <button type="button" class="resource-tag" data-cat="<%= cat %>"
                  aria-label="Filter by <%= cat %>" style="<%= badgeStyle(cat) %>"><%= cat %></button>
        <% } %>
      </div>
    <% } %>
    <% if (desc) { %>
      <p class="resource-desc"><%= desc %></p>
    <% } %>
  </li>
<% } %>
</ul>
```